<!DOCTYPE html>

</html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Advanced Stock Predictor | 7-Day Mathematical Forecast</title>
    <!-- Modern Typography -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --bg-dark: #0f172a;
            --text-light: #f8fafc;
            --glass-bg: rgba(30, 41, 59, 0.7);
            --glass-border: rgba(255, 255, 255, 0.12);
            --accent-primary: #3b82f6;
            --accent-hover: #2563eb;
            --success-color: #10b981;
            --danger-color: #ef4444;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
        }

        body {
            background-color: var(--bg-dark);
            background-image: radial-gradient(circle at top right, rgba(59, 130, 246, 0.15), transparent 40%),
                radial-gradient(circle at bottom left, rgba(16, 185, 129, 0.15), transparent 40%);
            color: var(--text-light);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 2rem 1rem;
        }

        .container {
            width: 100%;
            max-width: 1000px;
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        /* Glassmorphism Header */
        header {
            text-align: center;
            padding: 2rem;
            background: var(--glass-bg);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-radius: 1rem;
            border: 1px solid var(--glass-border);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
            animation: slideDown 0.6s ease-out;
        }

        h1 {
            font-weight: 700;
            font-size: 2.5rem;
            margin-bottom: 0.5rem;
            background: linear-gradient(135deg, #60a5fa, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        p.subtitle {
            color: #94a3b8;
            font-size: 1.1rem;
        }

        /* Input Section */
        .controls {
            display: flex;
            gap: 1rem;
            justify-content: center;
            align-items: center;
            background: var(--glass-bg);
            backdrop-filter: blur(16px);
            padding: 1.5rem;
            border-radius: 1rem;
            border: 1px solid var(--glass-border);
            animation: fadeIn 0.8s ease-out;
        }

        select {
            padding: 0.8rem 1.2rem;
            font-size: 1rem;
            background-color: rgba(15, 23, 42, 0.8);
            color: white;
            border: 1px solid #334155;
            border-radius: 0.5rem;
            outline: none;
            width: 200px;
            cursor: pointer;
            transition: border-color 0.2s;
        }

        select:focus {
            border-color: var(--accent-primary);
        }

        button.btn-primary {
            padding: 0.8rem 2rem;
            font-size: 1rem;
            font-weight: 600;
            color: white;
            background: var(--accent-primary);
            border: none;
            border-radius: 0.5rem;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: 0 4px 14px rgba(59, 130, 246, 0.4);
        }

        button.btn-primary:hover {
            background: var(--accent-hover);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(59, 130, 246, 0.5);
        }

        button.btn-primary:active {
            transform: translateY(0);
        }

        button:disabled {
            background: #475569;
            cursor: not-allowed;
            transform: none !important;
            box-shadow: none !important;
        }

        /* Loading State */
        .loader-container {
            display: none;
            flex-direction: column;
            align-items: center;
            gap: 1rem;
            margin-top: 2rem;
            color: #94a3b8;
        }

        .spinner {
            width: 40px;
            height: 40px;
            border: 4px solid rgba(255, 255, 255, 0.1);
            border-left-color: var(--accent-primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        /* Dashboard Section */
        .dashboard {
            display: none;
            grid-template-columns: 1fr;
            gap: 2rem;
            animation: slideUp 0.6s ease-out;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
        }

        .stat-card {
            background: var(--glass-bg);
            backdrop-filter: blur(16px);
            padding: 1.5rem;
            border-radius: 1rem;
            border: 1px solid var(--glass-border);
            text-align: center;
            transition: transform 0.3s;
        }

        .stat-card:hover {
            transform: translateY(-5px);
        }

        .stat-label {
            color: #94a3b8;
            font-size: 0.9rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 0.5rem;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 700;
        }

        .positive {
            color: var(--success-color);
        }

        .negative {
            color: var(--danger-color);
        }

        /* Chart Section */
        .chart-container {
            background: var(--glass-bg);
            backdrop-filter: blur(16px);
            padding: 1.5rem;
            border-radius: 1rem;
            border: 1px solid var(--glass-border);
            height: 400px;
            position: relative;
        }

        /* Animations */
        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        @keyframes spin {
            100% {
                transform: rotate(360deg);
            }
        }

        /* Day-Wise Table */
        .prediction-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1rem;
            background: rgba(15, 23, 42, 0.5);
            border-radius: 0.5rem;
            overflow: hidden;
        }

        .prediction-table th,
        .prediction-table td {
            padding: 1rem;
            text-align: left;
            border-bottom: 1px solid var(--glass-border);
        }

        .prediction-table th {
            background: rgba(255, 255, 255, 0.05);
            font-weight: 600;
            color: #e2e8f0;
        }

        .prediction-table tr:last-child td {
            border-bottom: none;
        }
    </style>
    < <style>
        /* Base specific styling for the new input to match the button */
        .controls input[type="text"] {
        padding: 0.8rem 1rem;
        border-radius: 0.5rem;
        border: 1px solid rgba(255, 255, 255, 0.2);
        background: rgba(15, 23, 42, 0.8);
        color: white;
        font-size: 1rem;
        outline: none;
        flex: 1;
        min-width: 200px;
        }
        .controls input[type="text"]:focus {
        border-color: var(--primary-color);
        box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.3);
        }
        /* Make placeholder text more readable */
        .controls input[type="text"]::placeholder {
        color: rgba(255, 255, 255, 0.5);
        }
        </style>
</head>

<body>
    <div class="container">
        <header>
            <h1>Advanced Quantitative Stock Predictor</h1>
            <p class="subtitle">Live Global Market Analysis & 30-Day Multi-Step Forecasting</p>
        </header>

        <div class="controls">
            <input type="text" id="tickerInput" list="tickerList" placeholder="e.g. AAPL, RELIANCE.NS, TSLA" disabled
                autocomplete="off">
            <datalist id="tickerList">
                <!-- Populated dynamically from API -->
            </datalist>
            <button id="predictBtn" class="btn-primary" disabled>Generate 1-Month Forecast</button>
        </div>

        <div class="loader-container" id="loader">
            <div class="spinner"></div>
            <p>Fetching Live Data & Training 30 independent XGBoost Models dynamically... please wait.</p>
        </div>

        <div class="dashboard" id="dashboard">
            <!-- News Section -->
            <div class="news-section" id="newsSection"
                style="display: none; background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(16px); padding: 1.5rem; border-radius: 1rem; border: 1px solid rgba(255,255,255,0.12); margin-bottom: 1rem;">
                <h3
                    style="margin-bottom: 1rem; color: #e2e8f0; font-size: 1.2rem; display: flex; justify-content: space-between;">
                    <span>Market Intelligence (Live News)</span>
                    <span id="dispSentiment"
                        style="padding: 0.2rem 0.8rem; border-radius: 1rem; font-size: 0.9rem;">-</span>
                </h3>
                <ul id="newsHeadlines"
                    style="list-style-type: none; padding-left: 0; color: #cbd5e1; font-size: 0.95rem; line-height: 1.6;">
                    <!-- Dynamically populated -->
                </ul>
            </div>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-label">Stock Ticker</div>
                    <div class="stat-value" id="dispTicker">-</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Current Price</div>
                    <div class="stat-value" id="dispCurrentPrice">-</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Day 30 Forecast</div>
                    <div class="stat-value" id="dispForecastPrice">-</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Predicted 1-Month Move</div>
                    <div class="stat-value" id="dispMove">-</div>
                </div>
            </div>

            <div class="chart-container">
                <canvas id="predictionChart"></canvas>
            </div>

            <div class="stat-card">
                <h3>Day-Wise Forecast Breakdown</h3>
                <table class="prediction-table" id="predictionTable">
                    <thead>
                        <tr>
                            <th>Day #</th>
                            <th>Date</th>
                            <th>Predicted Price</th>
                            <th>Change vs Current</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Populated dynamically -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        // Store Chart instance to update it
        let predictionChartInstance = null;
        const CACHE_BUST = Date.now(); // Helps prevent cache issues during local dev

        // 1. Fetch available tickers on load
        async function fetchTickers() {
            const input = document.getElementById('tickerInput');
            const dataList = document.getElementById('tickerList');
            const btn = document.getElementById('predictBtn');

            try {
                input.placeholder = "Loading popular tickers...";
                const response = await fetch('/api/tickers');
                const data = await response.json();

                if (data.tickers) {
                    dataList.innerHTML = '';
                    data.tickers.forEach(t => {
                        const opt = document.createElement('option');
                        opt.value = t;
                        dataList.appendChild(opt);
                    });
                    input.placeholder = "Search companies or tickers (e.g. Reliance, Zomato)...";
                    input.disabled = false;
                    btn.disabled = false;
                } else {
                    input.placeholder = "Error loading suggestions. Type any ticker.";
                    input.disabled = false;
                    btn.disabled = false;
                }
            } catch (error) {
                console.error("Failed to load tickers", error);
                input.placeholder = "Backend Not Running";
            }
        }

        // 1.5 Setup dynamic autocomplete search
        let searchTimeout = null;
        document.getElementById('tickerInput').addEventListener('input', (e) => {
            const query = e.target.value.trim();
            if (query.length < 2) return; // Wait for at least 2 chars

            if (searchTimeout) clearTimeout(searchTimeout);

            searchTimeout = setTimeout(async () => {
                try {
                    const response = await fetch(`/api/search?q=${encodeURIComponent(query)}`);
                    const results = await response.json();

                    if (results && results.length > 0) {
                        const dataList = document.getElementById('tickerList');
                        dataList.innerHTML = '';
                        results.forEach(res => {
                            const opt = document.createElement('option');
                            const exch = res.exchange ? ` (${res.exchange})` : '';
                            // Sets the visible dropdown label, but fills the input with the raw symbol on click
                            opt.value = res.symbol;
                            opt.textContent = `${res.name}${exch}`;
                            dataList.appendChild(opt);
                        });
                    }
                } catch (err) {
                    console.error("Search failed:", err);
                }
            }, 400); // 400ms debounce
        });

        // 2. Handle Predict Button Click
        document.getElementById('predictBtn').addEventListener('click', async () => {
            const inputField = document.getElementById('tickerInput');
            const ticker = inputField.value.trim().toUpperCase();
            if (!ticker) {
                alert("Please enter a valid stock ticker symbol.");
                return;
            }

            // UI State adjustments
            document.getElementById('predictBtn').disabled = true;
            inputField.disabled = true;
            document.getElementById('dashboard').style.display = 'none';
            document.getElementById('loader').style.display = 'flex';

            try {
                const response = await fetch('/api/predict', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ticker: ticker })
                });

                const data = await response.json();

                if (data.error) {
                    alert('Error: ' + data.error);
                } else {
                    updateDashboard(data);
                }
            } catch (error) {
                alert('Connection to backend failed. Make sure app.py is running.');
                console.error(error);
            } finally {
                document.getElementById('predictBtn').disabled = false;
                inputField.disabled = false;
                document.getElementById('loader').style.display = 'none';
            }
        });

        // 3. Update the UI with prediction metrics & chart
        function updateDashboard(data) {
            document.getElementById('dashboard').style.display = 'flex';
            document.getElementById('dashboard').style.flexDirection = 'column';

            const currentPrice = data.latest_price;
            const weekForecast = data.predictions[data.predictions.length - 1]; // Last Day
            const moveAmt = weekForecast - currentPrice;
            const movePct = (moveAmt / currentPrice) * 100;

            // Update News Sentiment
            if (data.sentiment) {
                document.getElementById('newsSection').style.display = 'block';
                const sScore = data.sentiment.score;
                const scoreBadge = document.getElementById('dispSentiment');
                if (sScore > 0.1) {
                    scoreBadge.textContent = "Positive (+" + sScore.toFixed(2) + ")";
                    scoreBadge.style.backgroundColor = 'rgba(16, 185, 129, 0.2)';
                    scoreBadge.style.color = 'var(--success-color)';
                } else if (sScore < -0.1) {
                    scoreBadge.textContent = "Negative (" + sScore.toFixed(2) + ")";
                    scoreBadge.style.backgroundColor = 'rgba(239, 68, 68, 0.2)';
                    scoreBadge.style.color = 'var(--danger-color)';
                } else {
                    scoreBadge.textContent = "Neutral (" + sScore.toFixed(2) + ")";
                    scoreBadge.style.backgroundColor = 'rgba(255, 255, 255, 0.1)';
                    scoreBadge.style.color = '#cbd5e1';
                }

                const hlList = document.getElementById('newsHeadlines');
                hlList.innerHTML = '';
                data.sentiment.headlines.forEach(hl => {
                    const li = document.createElement('li');
                    li.textContent = "• " + hl;
                    li.style.marginBottom = "0.5rem";
                    hlList.appendChild(li);
                });
            }

            // Update Stats Cards
            document.getElementById('dispTicker').textContent = data.ticker;
            document.getElementById('dispCurrentPrice').textContent = "$" + currentPrice.toFixed(2);
            document.getElementById('dispForecastPrice').textContent = "$" + weekForecast.toFixed(2);

            const moveEl = document.getElementById('dispMove');
            moveEl.textContent = (moveAmt > 0 ? "+" : "") + movePct.toFixed(2) + "%";
            moveEl.className = "stat-value " + (moveAmt >= 0 ? "positive" : "negative");

            // Build the Chart
            renderChart(data);

            // Populate Table
            const tbody = document.querySelector('#predictionTable tbody');
            tbody.innerHTML = '';

            data.predictions.forEach((pred, index) => {
                const dayOffset = index + 1;
                const dateTarget = data.future_dates[index];
                const change = ((pred - currentPrice) / currentPrice) * 100;

                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>Day ${dayOffset}</td>
                    <td>${dateTarget}</td>
                    <td>$${pred.toFixed(2)}</td>
                    <td class="${change >= 0 ? 'positive' : 'negative'}">${change >= 0 ? '+' : ''}${change.toFixed(2)}%</td>
                `;
                tbody.appendChild(tr);
            });
        }

        function renderChart(data) {
            const ctx = document.getElementById('predictionChart').getContext('2d');

            if (predictionChartInstance) {
                predictionChartInstance.destroy();
            }

            // Combine historical dates with future dates for x-axis
            const allDates = [...data.historical_data.dates, ...data.future_dates];

            // Historical line data (pad right side with nulls)
            const historicalPoints = [...data.historical_data.prices];
            for (let i = 0; i < data.future_dates.length; i++) {
                historicalPoints.push(null);
            }

            // Future line data (pad left side with nulls except for intersection)
            const futurePoints = Array(data.historical_data.prices.length - 1).fill(null);
            // Connect the last historical point to the future line
            futurePoints.push(data.latest_price);
            futurePoints.push(...data.predictions);

            // Create Gradient
            const gradientBlue = ctx.createLinearGradient(0, 0, 0, 400);
            gradientBlue.addColorStop(0, 'rgba(59, 130, 246, 0.5)');
            gradientBlue.addColorStop(1, 'rgba(59, 130, 246, 0.0)');

            predictionChartInstance = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: allDates,
                    datasets: [
                        {
                            label: 'Historical Close',
                            data: historicalPoints,
                            borderColor: '#3b82f6', // Blueprint Blue
                            backgroundColor: gradientBlue,
                            borderWidth: 2,
                            pointRadius: 1,
                            pointHoverRadius: 5,
                            fill: true,
                            tension: 0.1
                        },
                        {
                            label: 'XGBoost 1-Month Forecast',
                            data: futurePoints,
                            borderColor: '#10b981', // Emerald Green
                            borderDash: [5, 5],
                            borderWidth: 3,
                            pointRadius: 4,
                            pointHoverRadius: 6,
                            pointBackgroundColor: '#10b981',
                            fill: false,
                            tension: 0.2
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode: 'index',
                        intersect: false,
                    },
                    plugins: {
                        legend: {
                            labels: { color: '#e2e8f0', font: { family: 'Inter' } }
                        },
                        tooltip: {
                            backgroundColor: 'rgba(15, 23, 42, 0.9)',
                            titleColor: '#f8fafc',
                            bodyColor: '#cbd5e1',
                            borderColor: '#334155',
                            borderWidth: 1,
                            padding: 10,
                            displayColors: true,
                            callbacks: {
                                label: function (context) {
                                    let label = context.dataset.label || '';
                                    if (label) { label += ': '; }
                                    if (context.parsed.y !== null) {
                                        label += new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(context.parsed.y);
                                    }
                                    return label;
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            grid: { color: 'rgba(255, 255, 255, 0.05)' },
                            ticks: {
                                color: '#94a3b8',
                                maxTicksLimit: 15
                            }
                        },
                        y: {
                            grid: { color: 'rgba(255, 255, 255, 0.05)' },
                            ticks: {
                                color: '#94a3b8',
                                callback: function (value) { return '$' + value; }
                            }
                        }
                    }
                }
            });
        }

        // Initialize App
        fetchTickers();
    </script>
</body>

</html>